From c4d44b6a5cdbd6d03e664a6d9b47062556a299b3 Mon Sep 17 00:00:00 2001
From: affggh <879632264@qq.com>
Date: Mon, 8 Dec 2025 22:36:42 +0800
Subject: [PATCH] fix: fix shift overflow on emscripten


diff --git a/tools/insn.c b/tools/insn.c
index e025cfa..ac4432c 100644
--- a/tools/insn.c
+++ b/tools/insn.c
@@ -106,7 +106,7 @@ static inline uint64_t hweight64(u64 w)
  * position @h. For example
  * GENMASK_ULL(39, 21) gives us the 64bit vector 0x000000ffffe00000.
  */
-#ifndef _WIN32
+#if !(defined _WIN32) && !(defined __EMSCRIPTEN__)
 #define GENMASK(h, l) (((~0UL) << (l)) & (~0UL >> (BITS_PER_LONG - 1 - (h))))
 #else 
 #define GENMASK GENMASK_ULL
@@ -1460,4 +1460,4 @@ u32 aarch64_insn_gen_extr(enum aarch64_insn_variant variant, enum aarch64_insn_r
     insn = aarch64_insn_encode_register(AARCH64_INSN_REGTYPE_RD, insn, Rd);
     insn = aarch64_insn_encode_register(AARCH64_INSN_REGTYPE_RN, insn, Rn);
     return aarch64_insn_encode_register(AARCH64_INSN_REGTYPE_RM, insn, Rm);
-}
\ No newline at end of file
+}
